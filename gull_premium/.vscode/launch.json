{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart"
    },
    {
      "name": "Flutter (with env)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/gull_premium",
      "args": ["--dart-define-from-file=env.json"]
    },
    {
      "name": "Flutter (with Google Sign-In)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["--dart-define=GOOGLE_WEB_CLIENT_ID=PASTE_YOUR_WEB_CLIENT_ID.apps.googleusercontent.com"]
    }
  ]
}
